#!/bin/bash
# pre-commit hook - Validates JavaScript syntax before commit

GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo -e "${YELLOW}🔍 Running pre-commit checks...${NC}"

ERRORS=0

# Get list of staged JS files
JS_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.js$')

if [ -z "$JS_FILES" ]; then
    echo -e "${GREEN}✅ No JS files to check.${NC}"
    exit 0
fi

for file in $JS_FILES; do
    # Check for common syntax errors using node if available
    if command -v node >/dev/null 2>&1; then
        # Use node to check syntax (won't execute, just parse)
        node --check "$file" 2>/dev/null
        if [ $? -ne 0 ]; then
            echo -e "${RED}❌ Syntax error in: ${file}${NC}"
            ERRORS=$((ERRORS + 1))
        fi
    fi
    
    # Check for console.log left in code (warning only)
    if grep -n "console\.log" "$file" | grep -v "// debug" | grep -v "// test" > /dev/null 2>&1; then
        COUNT=$(grep -c "console\.log" "$file" 2>/dev/null || echo "0")
        echo -e "${YELLOW}⚠️  ${file}: ${COUNT} console.log statement(s) found${NC}"
    fi
    
    # Check for TODO/FIXME comments
    if grep -n "TODO\|FIXME\|HACK" "$file" > /dev/null 2>&1; then
        echo -e "${YELLOW}📌 ${file}: Contains TODO/FIXME comments${NC}"
    fi
done

if [ $ERRORS -gt 0 ]; then
    echo -e "${RED}❌ Pre-commit check failed with ${ERRORS} error(s).${NC}"
    exit 1
fi

echo -e "${GREEN}✅ All checks passed!${NC}"
exit 0
