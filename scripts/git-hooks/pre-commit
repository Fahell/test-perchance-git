#!/usr/bin/env node
// Git pre-commit hook: auto-sync version in for-perchance.html from constants.js

const fs = require('fs');
const path = require('path');
const { execSync } = require('child_process');

const CONSTANTS_PATH = path.join(__dirname, '../../src/constants.js');
const TARGET_PATH = path.join(__dirname, '../../for-perchance.html');

function extractVersion(content) {
  const match = content.match(/VERSION\s*=\s*['"](v[0-9]+\.[0-9]+\.[0-9]+)['"]/);
  return match ? match[1] : null;
}

function syncVersion(targetContent, newVersion) {
  const versionWithoutPrefix = newVersion.replace(/^v/, '');
  let count = 0;
  let updated = targetContent;
  updated = updated.replace(/@[\d.]+\//g, () => { count++; return `@${versionWithoutPrefix}/`; });
  updated = updated.replace(/@[\d.]+\.js/g, () => { count++; return `@${newVersion}.js`; });
  return { content: updated, count };
}

try {
  if (!fs.existsSync(CONSTANTS_PATH) || !fs.existsSync(TARGET_PATH)) {
    process.exit(0);
  }

  const constantsContent = fs.readFileSync(CONSTANTS_PATH, 'utf8');
  const targetContent = fs.readFileSync(TARGET_PATH, 'utf8');
  const version = extractVersion(constantsContent);

  if (!version) {
    console.warn('⚠️  Não foi possível extrair versão de constants.js');
    process.exit(0);
  }

  const { content: updatedContent, count } = syncVersion(targetContent, version);

  if (count > 0) {
    fs.writeFileSync(TARGET_PATH, updatedContent, 'utf8');
    execSync('git add for-perchance.html', { stdio: 'inherit' });
    console.log(`🔄 [pre-commit] for-perchance.html sincronizado para ${version} (${count} refs)`);
  }

  process.exit(0);
} catch (err) {
  console.error('❌ Erro no pre-commit hook:', err.message);
  process.exit(1);
}
