#!/usr/bin/env node
// Git pre-commit hook: always run sync-version.js (idempotent) to guarantee consistency

const { execSync } = require('child_process');
const path = require('path');

// __dirname = .git/hooks, so we need to go up 2 levels to reach repo root
const SYNC_SCRIPT = path.join(__dirname, '../../scripts/sync-version.js');

try {
  // Always execute sync (idempotent, ~50ms, guarantees correctness)
  execSync(`node "${SYNC_SCRIPT}"`, { stdio: 'inherit' });
  process.exit(0);
} catch (err) {
  console.error('❌ [pre-commit] sync-version.js falhou:', err.message);
  process.exit(1);
}
