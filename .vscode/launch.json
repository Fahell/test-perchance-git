{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Open test-local.html",
      "type": "chrome",
      "request": "launch",
      "file": "${workspaceFolder}/test-local.html",
      "webRoot": "${workspaceFolder}"
    },
    {
      "name": "Launch Chrome (localhost:8080)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:8080/test-local.html",
      "webRoot": "${workspaceFolder}"
    }
  ]
}
