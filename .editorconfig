# EditorConfig - https://editorconfig.org
# Mantém consistência de estilo entre editores

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[*.sh]
end_of_line = lf

[*.html]
indent_size = 2

[*.txt]
indent_size = 2

[*.yml]
indent_size = 2
