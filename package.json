{
  "name": "test-perchance-git",
  "version": "1.29.1",
  "description": "Projeto de teste para explorar as capacidades do Perchance com arquitetura modular usando ES6 Modules + GitHub + jsDelivr CDN. Agora com Vite bundling para performance otimizada.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "release": "node scripts/release.cjs",
    "refactor-imports": "node scripts/refactor-imports.js",
    "prepare": "husky",
    "lint": "eslint src/ scripts/ --ext .js,.cjs",
    "lint:fix": "eslint src/ scripts/ --ext .js,.cjs --fix",
    "format": "prettier --write \"src/**/*.{js,css}\" \"scripts/**/*.cjs\"",
    "format:check": "prettier --check \"src/**/*.{js,css}\" \"scripts/**/*.cjs\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "snapshot:create": "bash scripts/snapshot.sh create",
    "snapshot:restore": "bash scripts/snapshot.sh restore",
    "snapshot:list": "bash scripts/snapshot.sh list",
    "snapshot:delete": "bash scripts/snapshot.sh delete",
    "snapshot:cleanup": "bash scripts/snapshot.sh cleanup",
    "snapshot:info": "bash scripts/snapshot.sh info"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Fahell/test-perchance-git.git"
  },
  "keywords": [
    "perchance",
    "threejs",
    "es6-modules",
    "vite",
    "game"
  ],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Fahell/test-perchance-git/issues"
  },
  "homepage": "https://github.com/Fahell/test-perchance-git#readme",
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "globals": "^17.6.0",
    "husky": "^9.0.0",
    "prettier": "^3.0.0",
    "terser": "^5.39.0",
    "vite": "^6.0.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "howler": "^2.2.4"
  }
}
